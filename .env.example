# Copy to .env and fill in. See README for details.

# Postgres connection string (Neon / Vercel Postgres in production).
DATABASE_URL="postgresql://user:password@localhost:5432/aurevia_dev?schema=public"

# Resend — used to email new leads. Leave blank to disable email notifications.
RESEND_API_KEY=""
LEADS_NOTIFY_EMAIL="info@aureviaglobal.com"
LEADS_FROM_EMAIL="Aurevia Global <onboarding@resend.dev>"

# Credentials for the /admin lead viewer (username defaults to "admin" if unset).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
